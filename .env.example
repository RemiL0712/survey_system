# App
BOT_ID=1
BOT_TOKEN=change-me-telegram-bot-token
API_BASE_URL=http://api:8000/api/v1
SECRET_KEY=change-me-app-secret-key
ADMIN_API_TOKEN=change-me-internal-api-token
PYTHONUNBUFFERED=1

# Database and Redis
POSTGRES_PASSWORD=change-me-postgres-password
DATABASE_URL=postgresql+asyncpg://survey_user:change-me-postgres-password@postgres:5432/survey_db
REDIS_URL=redis://redis:6379

# Telegram admins
# You can keep only ADMIN_TG_IDS, or also duplicate the main admin in ADMIN_TG_ID.
ADMIN_TG_ID=
ADMIN_TG_IDS=123456789,987654321

# Web admin
ADMIN_WEB_PASSWORD=change-me-admin-password
ADMIN_WEB_SECRET=change-me-admin-cookie-secret
# Use false for plain HTTP. Switch to true only after HTTPS is configured.
ADMIN_WEB_COOKIE_SECURE=false

# Optional external ports
HTTP_PORT=80
